{
    "app-id": "com.adilhanney.super_nonogram",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "super_nonogram",
    "separate-locales": false,
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--socket=pulseaudio"
    ],
    "modules": [
        {
            "name": "super_nonogram",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app",
                "tar -xf SuperNonogram_*.tar.gz -C /app",
                "mkdir -p /app/bin",
                "ln -s /app/super_nonogram /app/bin/super_nonogram"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://github.com/adil192/super_nonogram/releases/download/v0.12.0/SuperNonogram_v0.12.0_Linux_x86_64.tar.gz",
                    "sha256": "5a92a961c9cb27b35c0c76a1cacb041ed058794af274bdb9532c2cb89f66408f",
                    "only-arches": [
                        "x86_64"
                    ],
                    "x-checker-data": {
                        "type": "json",
                        "url": "https://api.github.com/repos/adil192/super_nonogram/releases/latest",
                        "version-query": ".tag_name",
                        "url-query": ".assets[] | select(.name==\"SuperNonogram_\" + $version + \"_Linux_x86_64.tar.gz\") | .browser_download_url",
                        "is-main-source": false
                    }
                },
                {
                    "type": "file",
                    "url": "https://github.com/adil192/super_nonogram/releases/download/v0.12.0/SuperNonogram_v0.12.0_Linux_arm64.tar.gz",
                    "sha256": "280a2c952689b8e1a6162d2c190c1a24d956796c61f771765e3c7a54fda71a92",
                    "only-arches": [
                        "aarch64"
                    ],
                    "x-checker-data": {
                        "type": "json",
                        "url": "https://api.github.com/repos/adil192/super_nonogram/releases/latest",
                        "version-query": ".tag_name",
                        "url-query": ".assets[] | select(.name==\"SuperNonogram_\" + $version + \"_Linux_arm64.tar.gz\") | .browser_download_url",
                        "is-main-source": true
                    }
                }
            ]
        }
    ]
}
